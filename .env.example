# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key   # server-only; never expose to browser

# ─── Google OAuth (for GSC + GA4 connections) ────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# ─── LLM (Gemini default) ────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...your-gemini-key
LLM_PROVIDER=gemini
# Optional overrides — defaults are set in lib/llm/index.ts
# LLM_MODEL_FAST=gemini-2.0-flash
# LLM_MODEL_DEEP=gemini-1.5-pro
# LLM_MODEL_CHEAP=gemini-2.0-flash-lite

# ─── External APIs (used in Slice 2+) ────────────────────────────────────────
# Ahrefs: https://app.ahrefs.com/api
AHREFS_API_TOKEN=your-ahrefs-token
# Rankscale: dashboard → API key
RANKSCALE_API_KEY=your-rankscale-key
# Serper.dev: https://serper.dev/api-key
SERPER_API_KEY=your-serper-key

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
